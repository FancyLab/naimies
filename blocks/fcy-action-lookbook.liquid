{%- comment -%}
  fcy-action-lookbook — "See It In Action" UGC strip.

  Up to 6 slots: image (or video poster) + optional product link. Slots with
  no image are skipped, so merchants can grow/shrink the strip by filling
  or clearing slots.

  Markup-only: renders a flat <ul> with overflow-x scrolling as the
  graceful-degradation baseline. Styling (carousel controls, snap points,
  arrows) ships in a later phase.
{%- endcomment -%}

{%- assign block_settings = block.settings -%}
{%- assign heading = block_settings.heading | default: 'See It In Action' -%}

<fcy-action-lookbook
  class="fcy-action-lookbook{% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}"
  data-item-width="{{ block_settings.item_width | default: 92 }}"
  data-item-ratio="{{ block_settings.item_ratio | default: '2 / 3' }}"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  {%- if heading != blank -%}
    <p class="fcy-action-lookbook__heading">{{ heading | escape }}</p>
  {%- endif -%}

  <ul class="fcy-action-lookbook__list" role="list" data-lookbook-track>
    {%- for i in (1..6) -%}
      {%- assign image_key = 'item_' | append: i | append: '_image' -%}
      {%- assign product_key = 'item_' | append: i | append: '_product' -%}
      {%- assign caption_key = 'item_' | append: i | append: '_caption' -%}
      {%- assign image = block_settings[image_key] -%}
      {%- assign linked_product = all_products[block_settings[product_key]] -%}
      {%- assign caption = block_settings[caption_key] -%}

      {%- if image != blank -%}
        {%- assign tag = 'div' -%}
        {%- assign href = '' -%}
        {%- if linked_product != blank and linked_product.url != blank -%}
          {%- assign tag = 'a' -%}
          {%- assign href = linked_product.url -%}
        {%- endif -%}

        <li class="fcy-action-lookbook__item">
          <{{ tag }}
            class="fcy-action-lookbook__link"
            {% if tag == 'a' %}href="{{ href }}" aria-label="{{ linked_product.title | escape }}"{% endif %}
          >
            <div class="fcy-action-lookbook__media">
              {{
                image
                | image_url: width: 480
                | image_tag:
                    loading: 'lazy',
                    alt: caption | default: image.alt,
                    class: 'fcy-action-lookbook__image',
                    sizes: '(min-width: 750px) 120px, 92px',
                    widths: '120, 240, 360, 480'
              }}
            </div>
            {%- if caption != blank -%}
              <p class="fcy-action-lookbook__caption">{{ caption | escape }}</p>
            {%- endif -%}
          </{{ tag }}>
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</fcy-action-lookbook>

{% schema %}
{
  "name": "Fancyfy — Action lookbook",
  "class": "fcy-action-lookbook-block",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "See It In Action" },

    { "type": "header", "content": "Item 1" },
    { "type": "image_picker", "id": "item_1_image", "label": "Image" },
    { "type": "product", "id": "item_1_product", "label": "Linked product (optional)" },
    { "type": "text", "id": "item_1_caption", "label": "Caption (alt text / overlay)" },

    { "type": "header", "content": "Item 2" },
    { "type": "image_picker", "id": "item_2_image", "label": "Image" },
    { "type": "product", "id": "item_2_product", "label": "Linked product (optional)" },
    { "type": "text", "id": "item_2_caption", "label": "Caption" },

    { "type": "header", "content": "Item 3" },
    { "type": "image_picker", "id": "item_3_image", "label": "Image" },
    { "type": "product", "id": "item_3_product", "label": "Linked product (optional)" },
    { "type": "text", "id": "item_3_caption", "label": "Caption" },

    { "type": "header", "content": "Item 4" },
    { "type": "image_picker", "id": "item_4_image", "label": "Image" },
    { "type": "product", "id": "item_4_product", "label": "Linked product (optional)" },
    { "type": "text", "id": "item_4_caption", "label": "Caption" },

    { "type": "header", "content": "Item 5" },
    { "type": "image_picker", "id": "item_5_image", "label": "Image" },
    { "type": "product", "id": "item_5_product", "label": "Linked product (optional)" },
    { "type": "text", "id": "item_5_caption", "label": "Caption" },

    { "type": "header", "content": "Item 6" },
    { "type": "image_picker", "id": "item_6_image", "label": "Image" },
    { "type": "product", "id": "item_6_product", "label": "Linked product (optional)" },
    { "type": "text", "id": "item_6_caption", "label": "Caption" },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "item_width", "label": "Item width", "min": 60, "max": 200, "step": 4, "unit": "px", "default": 92 },
    { "type": "select", "id": "item_ratio", "label": "Item ratio",
      "options": [
        { "value": "2 / 3",  "label": "Portrait (2:3)" },
        { "value": "1 / 1",  "label": "Square (1:1)" },
        { "value": "3 / 4",  "label": "Tall (3:4)" },
        { "value": "9 / 16", "label": "Reel (9:16)" }
      ],
      "default": "2 / 3" },

    { "type": "header", "content": "Color" },
    { "type": "checkbox", "id": "inherit_color_scheme", "label": "Inherit color scheme from parent", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}" },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top",    "min": 0, "max": 80, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "padding-block-end",   "label": "Bottom", "min": 0, "max": 80, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "padding-inline-start","label": "Left",   "min": 0, "max": 80, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end",  "label": "Right",  "min": 0, "max": 80, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "Action lookbook", "category": "Fancyfy" }
  ]
}
{% endschema %}
