{%- comment -%}
  fcy-feature-pills — PDP "Matte Finish · Long Wearing · Blurring" row.

  Fixed-slot pattern (up to 5 pills). A pill renders only when its label
  is non-blank, so merchants add/remove by clearing the label.

  ADR-002: authored as a theme block with inline schema (fancyfy block
  pipeline pending — follow-up). ADR-003: consumes Horizon tokens; wraps
  markup in color-{{ scheme }} per the DS contract.
{%- endcomment -%}

{%- assign block_settings = block.settings -%}
{%- assign alignment = block_settings.alignment | default: 'flex-start' -%}
{%- assign gap = block_settings.gap | default: 12 -%}

<fcy-feature-pills
  class="fcy-feature-pills{% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}"
  data-alignment="{{ alignment }}"
  style="--fcy-pills-gap: {{ gap }}px; {% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  <ul
    class="fcy-feature-pills__list"
    role="list"
  >
    {%- for i in (1..5) -%}
      {%- assign label_key = 'pill_' | append: i | append: '_label' -%}
      {%- assign icon_key = 'pill_' | append: i | append: '_icon' -%}
      {%- assign label = block_settings[label_key] -%}
      {%- assign icon = block_settings[icon_key] -%}
      {%- if label != blank -%}
        <li class="fcy-feature-pills__item">
          {%- if icon != blank and icon != 'none' -%}
            <span class="fcy-feature-pills__icon" aria-hidden="true">
              {%- render 'icon-or-image', icon: icon, width: 20, class_name: 'fcy-feature-pills__icon-media' -%}
            </span>
          {%- endif -%}
          <span class="fcy-feature-pills__label">{{ label | escape }}</span>
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</fcy-feature-pills>

{% schema %}
