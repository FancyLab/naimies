{%- assign block_settings = block.settings -%}

<div
  class="fcy-payment-security{% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  {%- if block_settings.heading != blank -%}
    <p class="fcy-payment-security__heading">{{ block_settings.heading | escape }}</p>
  {%- endif -%}

  {%- assign has_icons = false -%}
  {%- for i in (1..8) -%}
    {%- assign img_key = 'icon_' | append: i | append: '_image' -%}
    {%- if block_settings[img_key] != blank -%}
      {%- assign has_icons = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_icons -%}
    <ul class="fcy-payment-security__icons" role="list">
      {%- for i in (1..8) -%}
        {%- assign img_key = 'icon_' | append: i | append: '_image' -%}
        {%- assign alt_key = 'icon_' | append: i | append: '_alt' -%}
        {%- assign img = block_settings[img_key] -%}
        {%- if img != blank -%}
          <li class="fcy-payment-security__icon-item">
            {{- img | image_url: width: 80 | image_tag:
              alt: block_settings[alt_key],
              width: 40,
              loading: 'lazy',
              class: 'fcy-payment-security__icon-img'
            -}}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  {%- endif -%}

  {%- if block_settings.legal_text != blank -%}
    <div class="fcy-payment-security__legal">{{ block_settings.legal_text }}</div>
  {%- endif -%}
</div>

{% stylesheet %}
  .fcy-payment-security {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .fcy-payment-security__heading {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: var(--font-size--xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .fcy-payment-security__icons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .fcy-payment-security__icon-item {
    display: inline-flex;
    align-items: center;
  }

  .fcy-payment-security__icon-img {
    display: block;
    height: 24px;
    width: auto;
    object-fit: contain;
    opacity: 0.7;
  }

  .fcy-payment-security__legal {
    font-size: var(--font-size--xs);
    line-height: 1.5;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .fcy-payment-security__legal p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fancyfy — Payment & Security",
  "class": "fcy-payment-security-block",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Payment & Security" },
    { "type": "richtext", "id": "legal_text", "label": "Legal text",
      "default": "<p>Your payment information is processed securely. We do not store credit card details nor have access to your credit card information.</p>" },

    { "type": "header", "content": "Icons (up to 8)" },

    { "type": "image_picker", "id": "icon_1_image", "label": "Icon 1" },
    { "type": "text",         "id": "icon_1_alt",   "label": "Icon 1 alt text" },

    { "type": "image_picker", "id": "icon_2_image", "label": "Icon 2" },
    { "type": "text",         "id": "icon_2_alt",   "label": "Icon 2 alt text" },

    { "type": "image_picker", "id": "icon_3_image", "label": "Icon 3" },
    { "type": "text",         "id": "icon_3_alt",   "label": "Icon 3 alt text" },

    { "type": "image_picker", "id": "icon_4_image", "label": "Icon 4" },
    { "type": "text",         "id": "icon_4_alt",   "label": "Icon 4 alt text" },

    { "type": "image_picker", "id": "icon_5_image", "label": "Icon 5" },
    { "type": "text",         "id": "icon_5_alt",   "label": "Icon 5 alt text" },

    { "type": "image_picker", "id": "icon_6_image", "label": "Icon 6" },
    { "type": "text",         "id": "icon_6_alt",   "label": "Icon 6 alt text" },

    { "type": "image_picker", "id": "icon_7_image", "label": "Icon 7" },
    { "type": "text",         "id": "icon_7_alt",   "label": "Icon 7 alt text" },

    { "type": "image_picker", "id": "icon_8_image", "label": "Icon 8" },
    { "type": "text",         "id": "icon_8_alt",   "label": "Icon 8 alt text" },

    { "type": "header", "content": "Color" },
    { "type": "checkbox", "id": "inherit_color_scheme", "label": "Inherit color scheme from parent", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}" },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start",   "label": "Top",    "min": 0, "max": 64, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding-block-end",     "label": "Bottom", "min": 0, "max": 64, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding-inline-start",  "label": "Left",   "min": 0, "max": 64, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end",    "label": "Right",  "min": 0, "max": 64, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "Payment & Security", "category": "Fancyfy" }
  ]
}
{% endschema %}
