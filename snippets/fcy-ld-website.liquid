{%- comment -%}
  fcy-ld-website — WebSite JSON-LD with optional Sitelinks Searchbox. Rendered once from layout/theme.liquid.
{%- endcomment -%}
{%- if settings.fancyfy_seo_website_enabled -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }}
      {%- if settings.fancyfy_seo_website_searchbox -%},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ shop.url | append: '/search?q={search_term_string}' | json }}
        },
        "query-input": "required name=search_term_string"
      }
      {%- endif -%}
    }
  </script>
{%- endif -%}
