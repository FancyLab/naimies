{%- comment -%}
  fcy-ld-website — WebSite JSON-LD with optional Sitelinks Searchbox. Rendered once from layout/theme.liquid.
{%- endcomment -%}
{%- if settings.fancyfy_seo_website_enabled -%}
  {%- capture fcy_search_url_template -%}{{ shop.url }}/search?q={search_term_string}{%- endcapture -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }}
      {%- if settings.fancyfy_seo_website_searchbox -%},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ fcy_search_url_template | json }}
        },
        "query-input": "required name=search_term_string"
      }
      {%- endif -%}
    }
  </script>
{%- endif -%}
