{%- comment -%}
  fcy-ld-faq — FAQPage JSON-LD.
  Params:
    faq_items  {Array}  — array of objects with .question and .answer strings
  Usage: {% render 'fcy-ld-faq', faq_items: my_faq_array %}
{%- endcomment -%}
{%- if faq_items.size > 0 -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for _faq in faq_items -%}
          {
            "@type": "Question",
            "name": {{ _faq.question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ _faq.answer | strip_html | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}
