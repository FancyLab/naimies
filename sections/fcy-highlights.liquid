{%- comment -%}
  fcy-highlights — Row of 3–5 icon + label highlights.

  Fixed-slot pattern: slots with a blank label are skipped, so merchants
  scale the row from 3 to 5 items without touching block children.
{%- endcomment -%}

{%- assign s = section.settings -%}
{%- assign alignment = s.alignment | default: 'center' -%}

<div class="fcy-highlights-wrapper color-{{ s.color_scheme }}">
  <fcy-highlights
    class="fcy-highlights section"
    data-alignment="{{ alignment }}"
    style="--fcy-highlights-gap: {{ s.gap | default: 32 }}px; {% render 'spacing-style', settings: s %}"
  >
    {%- if s.heading != blank -%}
      <h2 class="fcy-highlights__heading" style="text-align: {{ alignment }};">
        {{ s.heading | escape }}
      </h2>
    {%- endif -%}

    <ul class="fcy-highlights__list" role="list">
      {%- for i in (1..5) -%}
        {%- assign label_key = 'item_' | append: i | append: '_label' -%}
        {%- assign icon_key = 'item_' | append: i | append: '_icon' -%}
        {%- assign label = s[label_key] -%}
        {%- assign icon = s[icon_key] -%}
        {%- if label != blank -%}
          <li class="fcy-highlights__item">
            {%- if icon != blank and icon != 'none' -%}
              <span class="fcy-highlights__icon" aria-hidden="true">
                {%- render 'icon-or-image', icon: icon, width: s.icon_size | default: 28, class_name: 'fcy-highlights__icon-media' -%}
              </span>
            {%- endif -%}
            <span class="fcy-highlights__label">{{ label | escape }}</span>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </fcy-highlights>
</div>

