{%- comment -%}
  fcy-feature-duo — Two-column feature block: media + content (heading,
  body, checklist, CTA). Used twice on the PDP ("Why You'll Love It" with
  a before/after slider, and "About the Brand" reversed on a bg scheme).

  Media is merchant-selected inline (image, video, or before/after slider)
  rather than via blocks, so the three variants can expose tailored
  settings (e.g. before/after pill labels) directly on the section.
{%- endcomment -%}

{%- assign s = section.settings -%}
{%- assign layout = s.layout | default: 'image-right' -%}
{%- assign media_type = s.media_type | default: 'image' -%}

{%- if media_type == 'before-after' -%}
  <script src="{{ 'comparison-slider.js' | asset_url }}" type="module" fetchpriority="low"></script>
{%- endif -%}

<div
  class="fcy-feature-duo-wrapper section spacing-style color-{{ s.color_scheme }}"
  style="
    --fcy-duo-icon-size: {{ s.check_icon_size | default: 18 }}px;
    {% render 'spacing-style', settings: s %}
  "
>
  <fcy-feature-duo
    class="fcy-feature-duo"
    data-layout="{{ layout }}"
  >
    <div class="fcy-feature-duo__grid" data-layout="{{ layout }}">
      <div class="fcy-feature-duo__content">
        {%- if s.eyebrow != blank -%}
          <p class="fcy-feature-duo__eyebrow">{{ s.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if s.heading != blank -%}
          <h2 class="fcy-feature-duo__heading">{{ s.heading | escape }}</h2>
        {%- endif -%}

        {%- if s.body != blank -%}
          <div class="fcy-feature-duo__body">{{ s.body }}</div>
        {%- endif -%}

        <ul class="fcy-feature-duo__checklist" role="list">
          {%- for i in (1..5) -%}
            {%- assign item_key = 'item_' | append: i -%}
            {%- assign item = s[item_key] -%}
            {%- if item != blank -%}
              <li class="fcy-feature-duo__item">
                {%- if s.check_icon != blank -%}
                  <span class="fcy-feature-duo__check" aria-hidden="true">
                    {{
                      s.check_icon
                      | image_url: width: 64
                      | image_tag:
                          class: 'fcy-feature-duo__check-media',
                          alt: '',
                          width: s.check_icon_size,
                          height: s.check_icon_size,
                          loading: 'lazy'
                    }}
                  </span>
                {%- endif -%}
                <span class="fcy-feature-duo__item-text">{{ item }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        {%- if s.cta_label != blank -%}
          <a
            class="fcy-feature-duo__cta button button-primary"
            {% if s.cta_link != blank %}href="{{ s.cta_link }}"{% endif %}
          >
            <span>{{ s.cta_label | escape }}</span>
            {%- render 'icon-or-image', icon: 'arrow', width: 18, class_name: 'fcy-feature-duo__cta-icon' -%}
          </a>
        {%- endif -%}
      </div>

      <div class="fcy-feature-duo__media" data-media-type="{{ media_type }}">
        {%- case media_type -%}
          {%- when 'image' -%}
            {%- if s.image != blank -%}
              {{
                s.image
                | image_url: width: 1600
                | image_tag:
                    class: 'fcy-feature-duo__image',
                    alt: s.image.alt,
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    widths: '480, 720, 960, 1200, 1600',
                    loading: 'lazy'
              }}
            {%- else -%}
              <div class="fcy-feature-duo__placeholder">
                {{ 'product-apparel-1' | placeholder_svg_tag: 'fcy-feature-duo__placeholder-svg' }}
              </div>
            {%- endif -%}

          {%- when 'video' -%}
            {%- if s.video != blank -%}
              {{
                s.video
                | video_tag:
                    image_size: '1600x',
                    autoplay: s.video_autoplay,
                    loop: s.video_loop,
                    muted: true,
                    controls: s.video_controls,
                    class: 'fcy-feature-duo__video'
              }}
            {%- else -%}
              <div class="fcy-feature-duo__placeholder">
                {{ 'product-apparel-1' | placeholder_svg_tag: 'fcy-feature-duo__placeholder-svg' }}
              </div>
            {%- endif -%}

          {%- when 'before-after' -%}
            {%- assign ratio = 1 -%}
            {%- if s.before_image != blank -%}
              {%- assign ratio = s.before_image.aspect_ratio -%}
            {%- elsif s.after_image != blank -%}
              {%- assign ratio = s.after_image.aspect_ratio -%}
            {%- endif -%}
            {%- if ratio == 0 or ratio == null -%}
              {%- assign ratio = 1 -%}
            {%- endif -%}
            <comparison-slider-component
              class="fcy-feature-duo__compare comparison-slider comparison-slider--horizontal"
              style="--ratio: {{ ratio }};"
            >
              <div class="comparison-slider__container">
                <div
                  class="comparison-slider__media-wrapper"
                  ref="mediaWrapper"
                  data-comparison-slider
                  data-orientation="horizontal"
                  data-text-position="end"
                >
                  <div class="comparison-slider__layer comparison-slider__layer--before">
                    {%- if s.before_image != blank -%}
                      {{
                        s.before_image
                        | image_url: width: 1600
                        | image_tag:
                          loading: 'lazy',
                          class: 'before-image',
                          alt: s.before_image.alt,
                          sizes: '(min-width: 750px) 50vw, 100vw',
                          widths: '480, 720, 960, 1200, 1600',
                          ref: 'beforeImage'
                      }}
                    {%- else -%}
                      <div class="comparison-slider__placeholder before-image" ref="beforeImage">
                        {{ 'product-apparel-1' | placeholder_svg_tag }}
                      </div>
                    {%- endif -%}
                    {%- if s.show_labels and s.before_label != blank -%}
                      <div class="fcy-feature-duo__pill fcy-feature-duo__pill--before">
                        <span>{{ s.before_label | escape }}</span>
                      </div>
                    {%- endif -%}
                  </div>

                  <div class="comparison-slider__layer comparison-slider__layer--after">
                    {%- if s.after_image != blank -%}
                      {{
                        s.after_image
                        | image_url: width: 1600
                        | image_tag:
                          loading: 'lazy',
                          class: 'after-image',
                          alt: s.after_image.alt,
                          sizes: '(min-width: 750px) 50vw, 100vw',
                          widths: '480, 720, 960, 1200, 1600',
                          ref: 'afterImage'
                      }}
                    {%- else -%}
                      <div class="comparison-slider__placeholder after-image" ref="afterImage">
                        {{ 'product-apparel-2' | placeholder_svg_tag }}
                      </div>
                    {%- endif -%}
                    {%- if s.show_labels and s.after_label != blank -%}
                      <div class="fcy-feature-duo__pill fcy-feature-duo__pill--after">
                        <span>{{ s.after_label | escape }}</span>
                      </div>
                    {%- endif -%}
                  </div>

                  <div class="cs-slider__handle">
                    <span class="cs-slider__chevron">
                      {{- 'icon-chevron-left.svg' | inline_asset_content -}}
                    </span>
                    <span class="cs-slider__chevron">
                      {{- 'icon-chevron-right.svg' | inline_asset_content -}}
                    </span>
                  </div>

                  <input
                    type="range"
                    class="cs-slider"
                    ref="slider"
                    min="0"
                    max="100"
                    value="50"
                    aria-label="{{ 'blocks.slider_label' | t | default: 'Before and after comparison' }}"
                    on:input="/sync"
                    on:pointerdown="/sync"
                  >
                </div>
              </div>
            </comparison-slider-component>
        {%- endcase -%}
      </div>
    </div>
  </fcy-feature-duo>
</div>

{% stylesheet %}
  fcy-feature-duo {
    display: block;
    width: 100%;
  }

  .fcy-feature-duo__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  .fcy-feature-duo__grid[data-layout='image-left'] .fcy-feature-duo__content {
    order: 2;
  }

  .fcy-feature-duo__grid[data-layout='image-left'] .fcy-feature-duo__media {
    order: 1;
  }

  @media screen and (min-width: 750px) {
    .fcy-feature-duo__grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .fcy-feature-duo__content {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    min-width: 0;
  }

  .fcy-feature-duo__eyebrow {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: var(--font-size--xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .fcy-feature-duo__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: var(--font-size--3xl);
    font-weight: 600;
    line-height: 1.15;
  }

  .fcy-feature-duo__body {
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    line-height: 1.6;
  }

  .fcy-feature-duo__body p {
    margin: 0;
  }

  .fcy-feature-duo__checklist {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
  }

  .fcy-feature-duo__item {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-md);
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    line-height: 1.5;
  }

  .fcy-feature-duo__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: var(--fcy-duo-icon-size, 18px);
    height: var(--fcy-duo-icon-size, 18px);
    margin-top: 0.125rem;
  }

  .fcy-feature-duo__check-media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .fcy-feature-duo__item-text {
    flex: 1;
    min-width: 0;
  }

  .fcy-feature-duo__item-text p {
    margin: 0;
  }

  .fcy-feature-duo__cta {
    align-self: flex-start;
    margin-top: 1rem;
  }

  .fcy-feature-duo__media {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 0.75rem;
  }

  .fcy-feature-duo__image,
  .fcy-feature-duo__video {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .fcy-feature-duo__placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .fcy-feature-duo__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fcy-feature-duo__compare {
    display: block;
    width: 100%;
    border-radius: inherit;
  }

  .fcy-feature-duo__pill {
    position: absolute;
    bottom: 1rem;
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-radius: var(--style-border-radius-pills);
    font-family: var(--font-body--family);
    font-size: var(--font-size--xs);
    line-height: 1;
    pointer-events: none;
    z-index: 2;
  }

  .fcy-feature-duo__pill--before {
    left: 1rem;
  }

  .fcy-feature-duo__pill--after {
    right: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fancyfy — Feature duo",
  "tag": "section",
  "class": "fcy-feature-duo-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why You'll Love It" },
    { "type": "richtext", "id": "body", "label": "Body",
      "default": "<p>Our award-winning setting powder combines cutting-edge technology with clean, skin-caring ingredients. The weightless formula creates a soft-focus finish that photographs beautifully—perfect for everyday wear or special events.</p>" },

    { "type": "header", "content": "Checklist (clear to hide)" },
    { "type": "image_picker", "id": "check_icon", "label": "Bullet icon (SVG or image, leave blank to hide)" },
    { "type": "range", "id": "check_icon_size", "label": "Icon size", "min": 10, "max": 40, "step": 2, "unit": "px", "default": 18 },
    { "type": "richtext", "id": "item_1", "label": "Item 1",
      "default": "<p><strong>Invisible Finish:</strong> Ultra-fine milled powder blurs imperfections without looking cakey or settling into fine lines.</p>" },
    { "type": "richtext", "id": "item_2", "label": "Item 2",
      "default": "<p><strong>All-Day Wear:</strong> Locks in your makeup for 16+ hours while controlling oil and shine.</p>" },
    { "type": "richtext", "id": "item_3", "label": "Item 3",
      "default": "<p><strong>Skin-Perfecting Formula:</strong> Infused with light-reflecting pearls and skin-loving ingredients for a luminous, airbrushed effect.</p>" },
    { "type": "richtext", "id": "item_4", "label": "Item 4",
      "default": "<p><strong>Universal Shade Range:</strong> 8 expertly curated shades designed to complement every skin tone without oxidising or changing color.</p>" },
    { "type": "richtext", "id": "item_5", "label": "Item 5" },

    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_label", "label": "Label", "default": "Buy it now" },
    { "type": "url",  "id": "cta_link",  "label": "Link" },

    { "type": "header", "content": "Media" },
    { "type": "select", "id": "media_type", "label": "Media type",
      "options": [
        { "value": "image",         "label": "Image" },
        { "value": "video",         "label": "Video" },
        { "value": "before-after",  "label": "Before / After slider" }
      ],
      "default": "before-after" },

    { "type": "image_picker", "id": "image", "label": "Image",
      "visible_if": "{{ section.settings.media_type == 'image' }}" },

    { "type": "video", "id": "video", "label": "Video",
      "visible_if": "{{ section.settings.media_type == 'video' }}" },
    { "type": "checkbox", "id": "video_autoplay", "label": "Autoplay", "default": true,
      "visible_if": "{{ section.settings.media_type == 'video' }}" },
    { "type": "checkbox", "id": "video_loop",     "label": "Loop",     "default": true,
      "visible_if": "{{ section.settings.media_type == 'video' }}" },
    { "type": "checkbox", "id": "video_controls", "label": "Show controls", "default": false,
      "visible_if": "{{ section.settings.media_type == 'video' }}" },

    { "type": "image_picker", "id": "before_image", "label": "Before image",
      "visible_if": "{{ section.settings.media_type == 'before-after' }}" },
    { "type": "image_picker", "id": "after_image",  "label": "After image",
      "visible_if": "{{ section.settings.media_type == 'before-after' }}" },
    { "type": "checkbox", "id": "show_labels", "label": "Show Before/After labels", "default": true,
      "visible_if": "{{ section.settings.media_type == 'before-after' }}" },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "Before",
      "visible_if": "{{ section.settings.media_type == 'before-after' and section.settings.show_labels }}" },
    { "type": "text", "id": "after_label",  "label": "After label",  "default": "After 6 hours",
      "visible_if": "{{ section.settings.media_type == 'before-after' and section.settings.show_labels }}" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Media position",
      "options": [
        { "value": "image-right", "label": "Image on the right" },
        { "value": "image-left",  "label": "Image on the left (reverse)" }
      ],
      "default": "image-right" },

    { "type": "header", "content": "Color" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top",    "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding-block-end",   "label": "Bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding-inline-start","label": "Left",   "min": 0, "max": 80, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end",  "label": "Right",  "min": 0, "max": 80, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    {
      "name": "Fancyfy — Why you'll love it (before/after)",
      "category": "Fancyfy",
      "settings": {
        "heading": "Why You'll Love It",
        "media_type": "before-after",
        "show_labels": true,
        "before_label": "Before",
        "after_label": "After 6 hours",
        "layout": "image-right",
        "color_scheme": "scheme-1",
        "cta_label": "Buy it now"
      }
    },
    {
      "name": "Fancyfy — About the brand (reverse)",
      "category": "Fancyfy",
      "settings": {
        "eyebrow": "",
        "heading": "About the Brand",
        "body": "<p>Huda Beauty is known for creating high-performance makeup designed for both professional artists and everyday beauty lovers. Focused on innovation, texture, and long-wear results, the brand offers products that enhance confidence while supporting creative expression.</p>",
        "item_1": "<p><strong>Ultra-Fine Texture:</strong> Helps blur imperfections and smooth the look of skin without feeling heavy.</p>",
        "item_2": "<p><strong>Long-Wear Performance:</strong> Supports makeup longevity through busy days, events, and on-set use.</p>",
        "item_3": "<p><strong>Photo-Friendly Finish:</strong> Designed to reduce flashback and maintain a natural appearance under different lighting conditions.</p>",
        "item_4": "",
        "item_5": "",
        "cta_label": "",
        "media_type": "image",
        "layout": "image-left",
        "color_scheme": "scheme-2"
      }
    }
  ]
}
{% endschema %}
