{%- comment -%}
  fcy-feature-duo — Two-column feature block: media + content (heading,
  body, checklist, CTA). Used twice on the PDP ("Why You'll Love It" with
  a before/after slider, and "About the Brand" reversed on a bg scheme).

  Media is a child theme block — merchant drops Horizon's `image` OR
  `comparison-slider` via the block picker. Content is section-level
  settings (fixed-slot checklist, CTA).
{%- endcomment -%}

{%- assign s = section.settings -%}
{%- assign layout = s.layout | default: 'image-right' -%}

<div class="fcy-feature-duo-wrapper color-{{ s.color_scheme }}">
  <fcy-feature-duo
    class="fcy-feature-duo section"
    data-layout="{{ layout }}"
    style="{% render 'spacing-style', settings: s %}"
  >
    <div class="fcy-feature-duo__grid" data-layout="{{ layout }}">
      <div class="fcy-feature-duo__content">
        {%- if s.eyebrow != blank -%}
          <p class="fcy-feature-duo__eyebrow">{{ s.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if s.heading != blank -%}
          <h2 class="fcy-feature-duo__heading">{{ s.heading | escape }}</h2>
        {%- endif -%}

        {%- if s.body != blank -%}
          <div class="fcy-feature-duo__body">{{ s.body }}</div>
        {%- endif -%}

        <ul class="fcy-feature-duo__checklist" role="list">
          {%- for i in (1..5) -%}
            {%- assign item_key = 'item_' | append: i -%}
            {%- assign item = s[item_key] -%}
            {%- if item != blank -%}
              <li class="fcy-feature-duo__item">
                <span class="fcy-feature-duo__check" aria-hidden="true">
                  {%- render 'icon-or-image', icon: s.check_icon | default: 'check_box', width: 18, class_name: 'fcy-feature-duo__check-media' -%}
                </span>
                <span class="fcy-feature-duo__item-text">{{ item }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        {%- if s.cta_label != blank -%}
          <a
            class="fcy-feature-duo__cta button button-primary"
            {% if s.cta_link != blank %}href="{{ s.cta_link }}"{% endif %}
          >
            <span>{{ s.cta_label | escape }}</span>
            {%- render 'icon-or-image', icon: 'arrow', width: 18, class_name: 'fcy-feature-duo__cta-icon' -%}
          </a>
        {%- endif -%}
      </div>

      <div class="fcy-feature-duo__media" data-testid="feature-duo-media">
        {% content_for 'blocks' %}
      </div>
    </div>
  </fcy-feature-duo>
</div>

{% schema %}
{
  "name": "Fancyfy — Feature duo",
  "tag": "section",
  "class": "fcy-feature-duo-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [
    { "type": "image" },
    { "type": "comparison-slider" },
    { "type": "video" }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why You'll Love It" },
    { "type": "richtext", "id": "body", "label": "Body",
      "default": "<p>Our award-winning setting powder combines cutting-edge technology with clean, skin-caring ingredients. The weightless formula creates a soft-focus finish that photographs beautifully—perfect for everyday wear or special events.</p>" },

    { "type": "header", "content": "Checklist (clear to hide)" },
    { "type": "select", "id": "check_icon", "label": "Check icon",
      "options": [
        { "value": "check_box", "label": "Check" },
        { "value": "star", "label": "Star" },
        { "value": "heart", "label": "Heart" },
        { "value": "leaf", "label": "Leaf" }
      ],
      "default": "check_box" },
    { "type": "richtext", "id": "item_1", "label": "Item 1",
      "default": "<p><strong>Invisible Finish:</strong> Ultra-fine milled powder blurs imperfections without looking cakey or settling into fine lines.</p>" },
    { "type": "richtext", "id": "item_2", "label": "Item 2",
      "default": "<p><strong>All-Day Wear:</strong> Locks in your makeup for 16+ hours while controlling oil and shine.</p>" },
    { "type": "richtext", "id": "item_3", "label": "Item 3",
      "default": "<p><strong>Skin-Perfecting Formula:</strong> Infused with light-reflecting pearls and skin-loving ingredients for a luminous, airbrushed effect.</p>" },
    { "type": "richtext", "id": "item_4", "label": "Item 4",
      "default": "<p><strong>Universal Shade Range:</strong> 8 expertly curated shades designed to complement every skin tone without oxidising or changing color.</p>" },
    { "type": "richtext", "id": "item_5", "label": "Item 5", "default": "" },

    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_label", "label": "Label", "default": "Buy it now" },
    { "type": "url",  "id": "cta_link",  "label": "Link" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Media position",
      "options": [
        { "value": "image-right", "label": "Image on the right" },
        { "value": "image-left",  "label": "Image on the left (reverse)" }
      ],
      "default": "image-right" },

    { "type": "header", "content": "Color" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top",    "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding-block-end",   "label": "Bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding-inline-start","label": "Left",   "min": 0, "max": 80, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end",  "label": "Right",  "min": 0, "max": 80, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    {
      "name": "Fancyfy — Why you'll love it (before/after)",
      "category": "Fancyfy",
      "settings": {
        "heading": "Why You'll Love It",
        "layout": "image-right",
        "color_scheme": "scheme-1",
        "cta_label": "Buy it now"
      },
      "blocks": {
        "media": {
          "type": "comparison-slider",
          "settings": {
            "slider_style": "horizontal",
            "image_ratio": "adapt",
            "show_text": true,
            "before_text": "Before",
            "after_text": "After 6 hours",
            "text_position_horizontal": "bottom"
          }
        }
      },
      "block_order": ["media"]
    },
    {
      "name": "Fancyfy — About the brand (reverse)",
      "category": "Fancyfy",
      "settings": {
        "eyebrow": "",
        "heading": "About the Brand",
        "body": "<p>Huda Beauty is known for creating high-performance makeup designed for both professional artists and everyday beauty lovers. Focused on innovation, texture, and long-wear results, the brand offers products that enhance confidence while supporting creative expression.</p>",
        "item_1": "<p><strong>Ultra-Fine Texture:</strong> Helps blur imperfections and smooth the look of skin without feeling heavy.</p>",
        "item_2": "<p><strong>Long-Wear Performance:</strong> Supports makeup longevity through busy days, events, and on-set use.</p>",
        "item_3": "<p><strong>Photo-Friendly Finish:</strong> Designed to reduce flashback and maintain a natural appearance under different lighting conditions.</p>",
        "item_4": "",
        "item_5": "",
        "cta_label": "",
        "layout": "image-left",
        "color_scheme": "scheme-2"
      },
      "blocks": {
        "media": {
          "type": "image",
          "settings": {}
        }
      },
      "block_order": ["media"]
    }
  ]
}
{% endschema %}
