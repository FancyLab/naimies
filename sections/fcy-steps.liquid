{%- comment -%}
  fcy-steps — "How to use" numbered step list.

  Repeater pattern: up to 3 steps, each with an editable number, title (h4)
  and rich-text body. Numbers render inside a circular tinted badge whose
  background and foreground colours are merchant-controlled.

  Padding is handled by the Horizon .section.spacing-style pattern on the
  outer wrapper.
{%- endcomment -%}

{%- assign s = section.settings -%}
{%- assign alignment = s.alignment | default: 'center' -%}

<div
  class="fcy-steps-wrapper section spacing-style color-{{ s.color_scheme }}"
  style="
    --fcy-steps-num-bg: {{ s.number_bg_color }};
    --fcy-steps-num-fg: {{ s.number_text_color }};
    --fcy-steps-gap: {{ s.column_gap | default: 48 }}px;
    {% render 'spacing-style', settings: s %}
  "
>
  <fcy-steps class="fcy-steps">
    {%- if s.heading != blank -%}
      <h2 class="fcy-steps__heading" style="text-align: {{ alignment }};">
        {{ s.heading | escape }}
      </h2>
    {%- endif -%}

    <ol class="fcy-steps__list" role="list">
      {%- for i in (1..3) -%}
        {%- assign title_key  = 'step_' | append: i | append: '_title' -%}
        {%- assign body_key   = 'step_' | append: i | append: '_body' -%}
        {%- assign num_key    = 'step_' | append: i | append: '_number' -%}
        {%- assign title = s[title_key] -%}
        {%- assign body  = s[body_key] -%}
        {%- assign num   = s[num_key] | default: i -%}
        {%- if title != blank -%}
          <li class="fcy-steps__item">
            <div class="fcy-steps__badge" aria-hidden="true">{{ num }}.</div>
            <div class="fcy-steps__content">
              <h4 class="fcy-steps__title">{{ title | escape }}</h4>
              {%- if body != blank -%}
                <div class="fcy-steps__body">{{ body }}</div>
              {%- endif -%}
            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ol>
  </fcy-steps>
</div>

{% stylesheet %}
  fcy-steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .fcy-steps__heading {
    margin: 0 0 2.5rem;
    font-family: var(--font-heading--family);
  }

  .fcy-steps__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .fcy-steps__list {
      grid-template-columns: repeat(3, 1fr);
      column-gap: var(--fcy-steps-gap, 48px);
      row-gap: 2rem;
    }
  }

  .fcy-steps__item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .fcy-steps__badge {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background-color: var(--fcy-steps-num-bg);
    color: var(--fcy-steps-num-fg);
    font-family: var(--font-body--family);
    font-size: 1.875rem;
    font-weight: 400;
    line-height: 1;
  }

  .fcy-steps__content {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    padding-block-start: 0.5rem;
  }

  .fcy-steps__title {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: var(--font-size--xl);
    font-weight: 600;
  }

  .fcy-steps__body {
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    line-height: 1.5;
  }

  .fcy-steps__body p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fancyfy — Steps",
  "tag": "section",
  "class": "fcy-steps-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "How to Use" },

    { "type": "header", "content": "Step 1" },
    { "type": "text",     "id": "step_1_number", "label": "Number", "default": "1" },
    { "type": "text",     "id": "step_1_title",  "label": "Title",  "default": "Bake" },
    { "type": "richtext", "id": "step_1_body",   "label": "Body",   "default": "<p>Apply a generous layer of powder to areas you want to brighten or set, such as under the eyes, T-zone, smile lines, and chin.</p>" },

    { "type": "header", "content": "Step 2" },
    { "type": "text",     "id": "step_2_number", "label": "Number", "default": "2" },
    { "type": "text",     "id": "step_2_title",  "label": "Title",  "default": "Set" },
    { "type": "richtext", "id": "step_2_body",   "label": "Body",   "default": "<p>Lightly sweep powder across the face to lock in makeup and control shine. Focus on oily areas like the forehead, nose, and around the eyes.</p>" },

    { "type": "header", "content": "Step 3 (optional)" },
    { "type": "text",     "id": "step_3_number", "label": "Number", "default": "3" },
    { "type": "text",     "id": "step_3_title",  "label": "Title",  "default": "Touch up" },
    { "type": "richtext", "id": "step_3_body",   "label": "Body",   "default": "<p>Use throughout the day to refresh makeup and reduce shine without buildup. Perfect for quick on-the-go mattifying.</p>" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "alignment", "label": "Heading alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center",     "label": "Center" },
        { "value": "flex-end",   "label": "Right" }
      ],
      "default": "center" },
    { "type": "range", "id": "column_gap", "label": "Gap between columns", "min": 16, "max": 120, "step": 4, "unit": "px", "default": 48 },

    { "type": "header", "content": "Number badge" },
    { "type": "color", "id": "number_bg_color",   "label": "Badge background", "default": "#0A0A0A" },
    { "type": "color", "id": "number_text_color", "label": "Badge text color",  "default": "#FFFFFF" },

    { "type": "header", "content": "Color" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start",  "label": "Top",    "min": 0, "max": 128, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding-block-end",    "label": "Bottom", "min": 0, "max": 128, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding-inline-start", "label": "Left",   "min": 0, "max": 80,  "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end",   "label": "Right",  "min": 0, "max": 80,  "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    {
      "name": "Fancyfy — Steps",
      "category": "Fancyfy"
    }
  ]
}
{% endschema %}
