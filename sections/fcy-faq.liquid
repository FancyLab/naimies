{%- comment -%}
  fcy-faq — FAQ section with child Q/A blocks + optional "Contact us" CTA.

  Child blocks come from Horizon's `_accordion-row` so merchants get the
  familiar block picker and behaviour.
{%- endcomment -%}

{%- assign s = section.settings -%}

<div class="fcy-faq-wrapper color-{{ s.color_scheme }}">
  <fcy-faq
    class="fcy-faq section"
    style="{% render 'spacing-style', settings: s %}"
  >
    {%- if s.heading != blank -%}
      <h2 class="fcy-faq__heading" style="text-align: {{ s.heading_alignment | default: 'center' }};">
        {{ s.heading | escape }}
      </h2>
    {%- endif -%}

    <div class="fcy-faq__list">
      {% content_for 'blocks' %}
    </div>

    {%- if s.contact_label != blank or s.contact_link != blank -%}
      <div class="fcy-faq__footer" style="text-align: {{ s.footer_alignment | default: 'center' }};">
        {%- if s.contact_prompt != blank -%}
          <span class="fcy-faq__prompt">{{ s.contact_prompt | escape }}</span>
        {%- endif -%}
        {%- if s.contact_label != blank -%}
          <a
            class="fcy-faq__cta button button-secondary"
            {% if s.contact_link != blank %}href="{{ s.contact_link }}"{% endif %}
          >
            {{ s.contact_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </fcy-faq>
</div>

{% schema %}
{
  "name": "Fancyfy — FAQ",
  "tag": "section",
  "class": "fcy-faq-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [
    { "type": "_accordion-row" }
  ],
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Discover more in our FAQ" },
    { "type": "select", "id": "heading_alignment", "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center" },

    { "type": "header", "content": "Contact CTA (optional)" },
    { "type": "text", "id": "contact_prompt", "label": "Prompt text", "default": "Still have questions?" },
    { "type": "text", "id": "contact_label",  "label": "Button label", "default": "Contact Us" },
    { "type": "url",  "id": "contact_link",   "label": "Button link" },
    { "type": "select", "id": "footer_alignment", "label": "Footer alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center" },

    { "type": "header", "content": "Color" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top",    "min": 0, "max": 128, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding-block-end",   "label": "Bottom", "min": 0, "max": 128, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding-inline-start","label": "Left",   "min": 0, "max": 80, "step": 2, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end",  "label": "Right",  "min": 0, "max": 80, "step": 2, "unit": "px", "default": 0 }
  ],
  "presets": [
    {
      "name": "Fancyfy — FAQ",
      "category": "Fancyfy",
      "blocks": {
        "row_1": {
          "type": "_accordion-row",
          "settings": { "heading": "What skin types is this powder best for?", "open_by_default": true },
          "blocks": {
            "t": { "type": "text", "settings": { "text": "<p>This lightweight setting powder works especially well for normal, combination, and oily skin. It helps control shine while keeping makeup looking smooth and fresh.</p>", "type_preset": "rte", "alignment": "left" } }
          },
          "block_order": ["t"]
        },
        "row_2": {
          "type": "_accordion-row",
          "settings": { "heading": "Will this powder cause flashback in photos?" },
          "blocks": {
            "t": { "type": "text", "settings": { "text": "<p>No. The formula is photo-optimised and avoids the white cast you get with silica-heavy powders.</p>", "type_preset": "rte", "alignment": "left" } }
          },
          "block_order": ["t"]
        },
        "row_3": {
          "type": "_accordion-row",
          "settings": { "heading": "How do I choose the right shade?" },
          "blocks": {
            "t": { "type": "text", "settings": { "text": "<p>Translucent works across the shade range; tinted options are matched to our foundation family — match to your undertone, not your depth.</p>", "type_preset": "rte", "alignment": "left" } }
          },
          "block_order": ["t"]
        },
        "row_4": {
          "type": "_accordion-row",
          "settings": { "heading": "Can I use this powder for baking?" },
          "blocks": {
            "t": { "type": "text", "settings": { "text": "<p>Yes. Apply a generous layer under the eyes and T-zone, let it sit for 5–10 minutes, then dust away the excess.</p>", "type_preset": "rte", "alignment": "left" } }
          },
          "block_order": ["t"]
        },
        "row_5": {
          "type": "_accordion-row",
          "settings": { "heading": "How often should I replace this product?" },
          "blocks": {
            "t": { "type": "text", "settings": { "text": "<p>Every 12–18 months once opened, depending on use and storage.</p>", "type_preset": "rte", "alignment": "left" } }
          },
          "block_order": ["t"]
        },
        "row_6": {
          "type": "_accordion-row",
          "settings": { "heading": "Is this product suitable for professional makeup kits?" },
          "blocks": {
            "t": { "type": "text", "settings": { "text": "<p>Absolutely — it's a favorite in artist kits for long-wear editorial and bridal work.</p>", "type_preset": "rte", "alignment": "left" } }
          },
          "block_order": ["t"]
        }
      },
      "block_order": ["row_1", "row_2", "row_3", "row_4", "row_5", "row_6"]
    }
  ]
}
{% endschema %}
